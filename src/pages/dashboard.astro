---
// Fully standalone — no Layout, no shared styles, no blog components
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard</title>
    <link rel="manifest" href="/dashboard/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" href="/dashboard/icon-192.png" />
    <link rel="apple-touch-icon" href="/dashboard/icon-192.png" />
  </head>
  <body>
    <main>
      <h1>Dashboard</h1>
      <div class="grid">
        <a
          class="card"
          href="https://missionguess.github.io"
          target="_blank"
          rel="noopener"
        >
          <div class="card-body">
            <h2>Mission Guess</h2>
            <p>
              Interactive mission guessing app with map, admin panel, and TV display mode
            </p>
            <div class="tags">
              <span class="tag">SvelteKit</span>
              <span class="tag">Leaflet</span>
              <span class="tag">Supabase</span>
            </div>
          </div>
          <div class="card-links">
            <span class="link-pill">Live</span>
            <span
              class="link-pill gh"
              onclick="event.preventDefault(); event.stopPropagation(); window.open('https://github.com/missionguess/web', '_blank');"
              >GitHub</span
            >
          </div>
        </a>

        <a
          class="card"
          href="https://joshtune.github.io/mx-ideas-board-site"
          target="_blank"
          rel="noopener"
        >
          <div class="card-body">
            <h2>Ideas Board</h2>
            <p>Kanban board for tracking feature ideas across projects</p>
            <div class="tags">
              <span class="tag">Astro</span>
            </div>
          </div>
          <div class="card-links">
            <span class="link-pill">Live</span>
            <span
              class="link-pill gh"
              onclick="event.preventDefault(); event.stopPropagation(); window.open('https://github.com/joshtune/mx-ideas-board', '_blank');"
              >GitHub</span
            >
          </div>
        </a>

        <a
          class="card"
          href="https://joshtune.github.io/trend-idea-engine-site"
          target="_blank"
          rel="noopener"
        >
          <div class="card-body">
            <h2>Trend Idea Engine</h2>
            <p>Daily automated trend scraping + Claude-generated business ideas</p>
            <div class="tags">
              <span class="tag">Python</span>
              <span class="tag">GitHub Actions</span>
            </div>
          </div>
          <div class="card-links">
            <span class="link-pill">Live</span>
            <span
              class="link-pill gh"
              onclick="event.preventDefault(); event.stopPropagation(); window.open('https://github.com/joshtune/trend-idea-engine-site', '_blank');"
              >GitHub</span
            >
          </div>
        </a>

        <a class="card" href="https://joshtune.com" target="_blank" rel="noopener">
          <div class="card-body">
            <h2>Blog</h2>
            <p>Personal learning journal — MDX posts with code examples and charts</p>
            <div class="tags">
              <span class="tag">Astro</span>
              <span class="tag">MDX</span>
            </div>
          </div>
          <div class="card-links">
            <span class="link-pill">Live</span>
            <span
              class="link-pill gh"
              onclick="event.preventDefault(); event.stopPropagation(); window.open('https://github.com/joshtune/joshtune.github.io', '_blank');"
              >GitHub</span
            >
          </div>
        </a>
      </div>
    </main>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial,
          sans-serif;
        background: #0f172a;
        color: #e2e8f0;
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100dvh;
        padding: env(safe-area-inset-top) env(safe-area-inset-right)
          env(safe-area-inset-bottom) env(safe-area-inset-left);
      }

      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #f8fafc;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
      }

      .card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
        padding: 1.25rem;
        text-decoration: none;
        color: inherit;
        transition:
          border-color 0.15s,
          background 0.15s;
      }

      .card:hover {
        border-color: #60a5fa;
        background: #1e3a5f;
      }

      .card-body {
        flex: 1;
      }

      h2 {
        font-size: 1.1rem;
        font-weight: 600;
        color: #f8fafc;
        margin-bottom: 0.35rem;
      }

      p {
        font-size: 0.875rem;
        color: #94a3b8;
        line-height: 1.4;
        margin-bottom: 0.75rem;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        margin-bottom: 0.75rem;
      }

      .tag {
        font-size: 0.7rem;
        font-weight: 500;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        background: #334155;
        color: #94a3b8;
      }

      .card-links {
        display: flex;
        gap: 0.5rem;
      }

      .link-pill {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        background: #3b82f6;
        color: #fff;
        cursor: pointer;
      }

      .link-pill.gh {
        background: #374151;
        color: #d1d5db;
      }

      .link-pill.gh:hover {
        background: #4b5563;
      }

      @media (min-width: 520px) {
        .grid {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>
  </body>
</html>
